{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArtoisMailer",
  "version": "0.1.0",
  "identifier": "com.vp.artois-mailer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ArtoisMailer",
        "width": 1220,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
